# Ensures Python output is sent straight to stdout/stderr without buffering
PYTHONUNBUFFERED=1

# Origin allowed to call the API via CORS (the frontend's URL)
FRONTEND_ORIGIN=http://localhost:3000

# SQL Server audit log. Run backend/database/schema.sql in SSMS first to
# create the database/tables.
DB_ENABLED=true
DB_SERVER=localhost\SQLEXPRESS
DB_NAME=CQNMS_DB
DB_DRIVER=ODBC Driver 17 for SQL Server

# Leave DB_USER/DB_PASSWORD blank for local runs - Windows Authentication is used
# instead (Trusted_Connection). Only set these for SQL Authentication, e.g. when
# connecting from Docker (see CQNMS/.env.example for the Docker-side setup).
DB_USER=
DB_PASSWORD=
